             RowBox[{
              RowBox[{"(", 
               RowBox[{"u", "-", 
                RowBox[{"4", 
                 RowBox[{"\[Mu]", "^", "2"}]}]}], ")"}], "/", "4"}]}], 
            "]"}]}], ")"}]}]}]}]}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Differentiate", " ", "once", " ", "symbolically"}], ",", 
    RowBox[{"then", " ", "reuse"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"M4ds", "[", 
     RowBox[{"s_", ",", "t_", ",", "\[Mu]_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"M4", "[", 
        RowBox[{"\[Sigma]", ",", "t", ",", "\[Mu]"}], "]"}], ",", 
       "\[Sigma]"}], "]"}], "/.", " ", 
     RowBox[{"\[Sigma]", "->", "s"}]}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Analytic", " ", "residue", " ", "formula"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"residueExpr", "[", 
     RowBox[{"\[Mu]_", ",", "t_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"M4ds", "[", 
          RowBox[{
           RowBox[{"2", " ", 
            RowBox[{"\[Mu]", "^", "2"}]}], ",", "t", ",", "\[Mu]"}], "]"}], "*",
          "t"}], ")"}], "-", 
       RowBox[{"M4", "[", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{"\[Mu]", "^", "2"}]}], ",", "t", ",", "\[Mu]"}], "]"}], "+", 
       RowBox[{"M4", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{"\[Mu]", "^", "2"}]}], "-", "t"}], ",", "t", ",", 
         "\[Mu]"}], "]"}]}], ")"}], "/", 
     RowBox[{"t", "^", "2"}]}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Compute", " ", "the", " ", "t"}], "-", 
    RowBox[{"series", " ", "once"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"g2Expr", "=", 
   RowBox[{"SeriesCoefficient", "[", 
    RowBox[{
     RowBox[{"residueExpr", "[", 
      RowBox[{"\[Mu]", ",", "\[Tau]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Tau]", ",", "0", ",", "0"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"g3Expr", "=", 
    RowBox[{"SeriesCoefficient", "[", 
     RowBox[{
      RowBox[{"residueExpr", "[", 
       RowBox[{"\[Mu]", ",", "\[Tau]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Tau]", ",", "0", ",", "1"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Optional", " ", "simplification", " ", "once"}], ",", 
    RowBox[{"not", " ", "inside", " ", "Plot"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ratioExpr", "=", 
    RowBox[{"Simplify", "[", 
     RowBox[{
      RowBox[{"g3Expr", "/", "g2Expr"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"0", "<", "\[Mu]", "<", 
        RowBox[{"2", "/", "5"}]}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Numeric", " ", "plotting", " ", "function"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ratio", "[", 
     RowBox[{"m_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"N", "[", 
     RowBox[{
      RowBox[{"ratioExpr", "/.", " ", 
       RowBox[{"\[Mu]", "->", "m"}]}], ",", "600"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"ratio", "[", "m", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"m", ",", 
     RowBox[{"1", "/", "1000"}], ",", 
     RowBox[{"4", "/", "10"}]}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"WorkingPrecision", "->", "600"}], ",", 
   RowBox[{"PlotPoints", "->", "25"}], ",", 
   RowBox[{"MaxRecursion", "->", "2"}]}], "]"}]}], "Input",
