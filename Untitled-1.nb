Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "A4", ",", "M4", ",", "M4ds", ",", "residueExpr", ",", "g2Expr", ",", 
     "g3Expr", ",", "ratioExpr", ",", "ratio", ",", "\[Mu]", ",", "\[Tau]", ",",
      "\[Sigma]"}], "]"}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"5", "d", " ", "amplitude"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"A4", "[", 
     RowBox[{"s_", ",", "t_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"u", "=", 
        RowBox[{
         RowBox[{"-", "s"}], "-", "t"}]}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"s", "^", "2"}], "+", 
          RowBox[{"t", "^", "2"}], "+", 
          RowBox[{"u", "^", "2"}]}], ")"}], "^", "2"}], "*", 
       RowBox[{"Gamma", "[", 
        RowBox[{
         RowBox[{"-", "s"}], "/", "4"}], "]"}], " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{
         RowBox[{"-", "t"}], "/", "4"}], "]"}], " ", 
       RowBox[{
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"-", "u"}], "/", "4"}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Gamma", "[", 
           RowBox[{"1", "+", 
            RowBox[{"s", "/", "4"}]}], "]"}], " ", 
          RowBox[{"Gamma", "[", 
           RowBox[{"1", "+", 
            RowBox[{"t", "/", "4"}]}], "]"}], " ", 
          RowBox[{"Gamma", "[", 
           RowBox[{"1", "+", 
            RowBox[{"u", "/", "4"}]}], "]"}]}], ")"}]}]}]}], "]"}]}], ";"}], 
  "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "4", "d", " ", "symmetric", " ", "amplitude", " ", "with", " ", "explicit",
     " ", "KK", " ", "mass", " ", "parameter", " ", "\[Mu]"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"M4", "[", 
     RowBox[{"s_", ",", "t_", ",", "\[Mu]_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"u", "=", 
        RowBox[{
         RowBox[{"4", 
          RowBox[{"\[Mu]", "^", "2"}]}], "-", "s", "-", "t"}]}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"s", "-", 
              RowBox[{"4", 
               RowBox[{"\[Mu]", "^", "2"}]}]}], ")"}], "^", "2"}], "+", 
           RowBox[{"t", "^", "2"}], "+", 
           RowBox[{"u", "^", "2"}]}], ")"}], "^", "2"}], "*", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"s", "-", 
             RowBox[{"4", 
              RowBox[{"\[Mu]", "^", "2"}]}]}], ")"}]}], "/", "4"}], "]"}], " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"-", "t"}], "/", "4"}], "]"}], " ", 
        RowBox[{
         RowBox[{"Gamma", "[", 
          RowBox[{
           RowBox[{"-", "u"}], "/", "4"}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Gamma", "[", 
            RowBox[{"1", "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"s", "-", 
                RowBox[{"4", 
                 RowBox[{"\[Mu]", "^", "2"}]}]}], ")"}], "/", "4"}]}], "]"}], 
           " ", 
           RowBox[{"Gamma", "[", 
            RowBox[{"1", "+", 
             RowBox[{"t", "/", "4"}]}], "]"}], " ", 
           RowBox[{"Gamma", "[", 
            RowBox[{"1", "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"s", "-", 
                RowBox[{"4", 
                 RowBox[{"\[Mu]", "^", "2"}]}]}], ")"}], "/", "4"}]}], 
            "]"}]}], ")"}]}]}], "+", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"s", "^", "2"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"t", "-", 
              RowBox[{"4", 
               RowBox[{"\[Mu]", "^", "2"}]}]}], ")"}], "^", "2"}], "+", 
           RowBox[{"u", "^", "2"}]}], ")"}], "^", "2"}], "*", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"-", "s"}], "/", "4"}], "]"}], " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"t", "-", 
             RowBox[{"4", 
              RowBox[{"\[Mu]", "^", "2"}]}]}], ")"}]}], "/", "4"}], "]"}], " ", 
        RowBox[{
         RowBox[{"Gamma", "[", 
          RowBox[{
           RowBox[{"-", "u"}], "/", "4"}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Gamma", "[", 
            RowBox[{"1", "+", 
             RowBox[{"s", "/", "4"}]}], "]"}], " ", 
           RowBox[{"Gamma", "[", 
            RowBox[{"1", "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"t", "-", 
                RowBox[{"4", 
                 RowBox[{"\[Mu]", "^", "2"}]}]}], ")"}], "/", "4"}]}], "]"}], 
           " ", 
           RowBox[{"Gamma", "[", 
            RowBox[{"1", "+", 
             RowBox[{"s", "/", "4"}]}], "]"}]}], ")"}]}]}], "+", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"s", "^", "2"}], "+", 
           RowBox[{"t", "^", "2"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"u", "-", 
              RowBox[{"4", 
               RowBox[{"\[Mu]", "^", "2"}]}]}], ")"}], "^", "2"}]}], ")"}], "^",
          "2"}], "*", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"-", "s"}], "/", "4"}], "]"}], " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"-", "t"}], "/", "4"}], "]"}], " ", 
        RowBox[{
         RowBox[{"Gamma", "[", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"u", "-", 
              RowBox[{"4", 
               RowBox[{"\[Mu]", "^", "2"}]}]}], ")"}]}], "/", "4"}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Gamma", "[", 
            RowBox[{"1", "+", 
             RowBox[{"s", "/", "4"}]}], "]"}], " ", 
           RowBox[{"Gamma", "[", 
            RowBox[{"1", "+", 
             RowBox[{"t", "/", "4"}]}], "]"}], " ", 
           RowBox[{"Gamma", "[", 
