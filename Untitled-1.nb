Notebook[{

Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "A4", ",", "M4", ",", "M4ds", ",", "residueExpr", ",", "g2Expr", ",", 
     "g3Expr", ",", "ratioExpr", ",", "ratio", ",", "\[Mu]", ",", "\[Tau]", ",",
      "\[Sigma]"}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"5", "d", " ", "amplitude"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"A4", "[", 
     RowBox[{"s_", ",", "t_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"u", "=", 
        RowBox[{
         RowBox[{"-", "s"}], "-", "t"}]}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"s", "^", "2"}], "+", 
          RowBox[{"t", "^", "2"}], "+", 
          RowBox[{"u", "^", "2"}]}], ")"}], "^", "2"}], "*", 
       RowBox[{"Gamma", "[", 
        RowBox[{
         RowBox[{"-", "s"}], "/", "4"}], "]"}], " ", 
       RowBox[{"Gamma", "[", 
        RowBox[{
         RowBox[{"-", "t"}], "/", "4"}], "]"}], " ", 
       RowBox[{
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"-", "u"}], "/", "4"}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Gamma", "[", 
           RowBox[{"1", "+", 
            RowBox[{"s", "/", "4"}]}], "]"}], " ", 
          RowBox[{"Gamma", "[", 
           RowBox[{"1", "+", 
            RowBox[{"t", "/", "4"}]}], "]"}], " ", 
          RowBox[{"Gamma", "[", 
           RowBox[{"1", "+", 
            RowBox[{"u", "/", "4"}]}], "]"}]}], ")"}]}]}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "4", "d", " ", "symmetric", " ", "amplitude", " ", "with", " ", "explicit",
     " ", "KK", " ", "mass", " ", "parameter", " ", "\[Mu]"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"M4", "[", 
     RowBox[{"s_", ",", "t_", ",", "\[Mu]_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"u", "=", 
        RowBox[{
         RowBox[{"4", " ", 
          RowBox[{"\[Mu]", "^", "2"}]}], "-", "s", "-", "t"}]}], "}"}], ",", 
      RowBox[{
       RowBox[{"A4", "[", 
        RowBox[{
         RowBox[{"s", "+", 
          RowBox[{"4", " ", 
           RowBox[{"\[Mu]", "^", "2"}]}]}], ",", "t"}], "]"}], "+", 
       RowBox[{"A4", "[", 
        RowBox[{"s", ",", 
         RowBox[{"t", "+", 
          RowBox[{"4", " ", 
           RowBox[{"\[Mu]", "^", "2"}]}]}]}], "]"}], "+", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"s", "^", "2"}], "+", 
           RowBox[{"t", "^", "2"}], "+", 
           RowBox[{"u", "^", "2"}]}], ")"}], "^", "2"}], "*", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"-", "s"}], "/", "4"}], "]"}], " ", 
        RowBox[{"Gamma", "[", 
         RowBox[{
          RowBox[{"-", "t"}], "/", "4"}], "]"}], " ", 
        RowBox[{
         RowBox[{"Gamma", "[", 
          RowBox[{
           RowBox[{"-", "u"}], "/", "4"}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Gamma", "[", 
            RowBox[{"1", "+", 
             RowBox[{"s", "/", "4"}]}], "]"}], " ", 
           RowBox[{"Gamma", "[", 
            RowBox[{"1", "+", 
             RowBox[{"t", "/", "4"}]}], "]"}], " ", 
           RowBox[{"Gamma", "[", 
            RowBox[{"1", "+", 
             RowBox[{"u", "/", "4"}]}], "]"}]}], ")"}]}]}]}]}], "]"}]}], 
   ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Differentiate", " ", "once", " ", "symbolically"}], ",", 
    RowBox[{"then", " ", "reuse"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"M4ds", "[", 
     RowBox[{"s_", ",", "t_", ",", "\[Mu]_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"M4", "[", 
        RowBox[{"\[Sigma]", ",", "t", ",", "\[Mu]"}], "]"}], ",", 
       "\[Sigma]"}], "]"}], "/.", " ", 
     RowBox[{"\[Sigma]", "->", "s"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Analytic", " ", "residue", " ", "formula"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"residueExpr", "[", 
     RowBox[{"\[Mu]_", ",", "t_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"M4ds", "[", 
          RowBox[{
           RowBox[{"2", " ", 
            RowBox[{"\[Mu]", "^", "2"}]}], ",", "t", ",", "\[Mu]"}], "]"}], "*",
          "t"}], ")"}], "-", 
       RowBox[{"M4", "[", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{"\[Mu]", "^", "2"}]}], ",", "t", ",", "\[Mu]"}], "]"}], "+", 
       RowBox[{"M4", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{"\[Mu]", "^", "2"}]}], "-", "t"}], ",", "t", ",", 
         "\[Mu]"}], "]"}]}], ")"}], "/", 
     RowBox[{"t", "^", "2"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Compute", " ", "the", " ", "t"}], "-", 
    RowBox[{"series", " ", "once"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"g2Expr", "=", 
   RowBox[{"SeriesCoefficient", "[", 
    RowBox[{
     RowBox[{"residueExpr", "[", 
      RowBox[{"\[Mu]", ",", "\[Tau]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Tau]", ",", "0", ",", "0"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"g3Expr", "=", 
    RowBox[{"SeriesCoefficient", "[", 
     RowBox[{
      RowBox[{"residueExpr", "[", 
       RowBox[{"\[Mu]", ",", "\[Tau]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Tau]", ",", "0", ",", "1"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Optional", " ", "simplification", " ", "once"}], ",", 
    RowBox[{"not", " ", "inside", " ", "Plot"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ratioExpr", "=", 
    RowBox[{"Simplify", "[", 
     RowBox[{
      RowBox[{"g3Expr", "/", "g2Expr"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"0", "<", "\[Mu]", "<", 
        RowBox[{"2", "/", "5"}]}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\n", 
  RowBox[{"(*", 
   RowBox[{"Numeric", " ", "plotting", " ", "function"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"ratio", "[", 
     RowBox[{"m_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"N", "[", 
     RowBox[{
      RowBox[{"ratioExpr", "/.", " ", 
       RowBox[{"\[Mu]", "->", "m"}]}], ",", "30"}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"ratio", "[", "m", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"m", ",", 
     RowBox[{"1", "/", "10"}], ",", 
     RowBox[{"4", "/", "10"}]}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"WorkingPrecision", "->", "200"}], ",", 
   RowBox[{"PlotPoints", "->", "25"}], ",", 
   RowBox[{"MaxRecursion", "->", "2"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9884074501007404`*^9, 3.9884074501007404`*^9}, {
  3.988407670485817*^9, 3.98840767129175*^9}, {3.988407730295862*^9, 
  3.988407731637764*^9}},
