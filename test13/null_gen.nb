  RowBox[{"largeJ", "[", 
   RowBox[{"list_List", ",", 
    RowBox[{"J_Symbol", ":", "J"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "p", "}"}], ",", 
