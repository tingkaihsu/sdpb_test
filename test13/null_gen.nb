Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", "largeJ", "]"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"largeJ", "[", 
   RowBox[{"list_List", ",", 
    RowBox[{"J_Symbol", ":", "J"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "p", "}"}], ",", 
    RowBox[{
     RowBox[{"p", "=", 
      RowBox[{"Max", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Exponent", "[", 
          RowBox[{
           RowBox[{"Together", "@", 
            RowBox[{"Simplify", "[", "#", "]"}]}], ",", "J"}], "]"}], "&"}], "/@",
         "list"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Assuming", "[", 
      RowBox[{
       RowBox[{"J", ">", "0"}], ",", 
       RowBox[{"Limit", "[", 
        RowBox[{
