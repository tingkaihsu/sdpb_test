Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"DblCtrSum", "[", 
    RowBox[{"s_", ",", "k_", ",", "q_"}], "]"}], ":=", 
   RowBox[{"Residue", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         FractionBox["1", 
          RowBox[{"s", "*", "t"}]], "*", 
         RowBox[{"(", 
          RowBox[{
           FractionBox["1", 
            RowBox[{
             RowBox[{"s", "^", 
              RowBox[{"(", 
               RowBox[{"k", "-", "q"}], ")"}]}], "*", 
             RowBox[{"t", "^", "q"}]}]], "-", 
           FractionBox["1", 
            RowBox[{
             RowBox[{"s", "^", "q"}], "*", 
             RowBox[{"t", "^", 
              RowBox[{"(", 
               RowBox[{"k", "-", "q"}], ")"}]}]}]]}], ")"}]}], "-", 
        RowBox[{
         FractionBox["1", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "s"}], "-", "t"}], ")"}], "*", "t"}]], "*", 
         RowBox[{"(", 
          RowBox[{
           FractionBox["1", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"-", "s"}], "-", "t"}], ")"}], "^", 
              RowBox[{"(", 
               RowBox[{"k", "-", "q"}], ")"}]}], "*", 
             RowBox[{"t", "^", "q"}]}]], "-", 
           FractionBox["1", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"-", "s"}], "-", "t"}], ")"}], "^", "q"}], "*", 
             RowBox[{"t", "^", 
              RowBox[{"(", 
               RowBox[{"k", "-", "q"}], ")"}]}]}]]}], ")"}]}]}], ")"}], "*", 
      RowBox[{"PartialWaveD", "[", 
       RowBox[{"10", ",", "J", ",", 
        RowBox[{"1", "+", 
         FractionBox[
          RowBox[{"2", "t"}], "s"]}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0"}], "}"}]}], "]"}]}], ";"}]], "Input",
